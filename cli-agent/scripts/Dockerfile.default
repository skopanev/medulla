FROM node:24-bookworm

# System tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    git ripgrep bash curl ca-certificates \
    python3 python3-pip pipx jq sudo \
    dbus gnome-keyring libsecret-tools \
    && rm -rf /var/lib/apt/lists/* \
    && rm -f /usr/lib/python3.*/EXTERNALLY-MANAGED

# AI panel tools
RUN npm install -g @anthropic-ai/claude-code @openai/codex opencode-ai

# cx: optional codex wrapper for the hltm token-broker. When a broker config is
# present (~/.config/hltm-broker, auto-mounted by docker.py build_volumes) cx
# fetches a fresh token and overwrites ~/.codex/auth.json before exec'ing codex,
# so the broker stays the sole auth authority (no rotation race). Account =
# $CX_ACCOUNT (default "default"); set CX_ACCOUNT=<you> in ~/.medulla/.env to run
# the codex panelist under your own broker account. With NO broker config cx is a
# transparent pass-through to plain codex, so non-broker installs are unaffected
# (the codex harness prefers cx on PATH — see v2/harness.py).
RUN printf '%s\n' \
    '#!/bin/sh' \
    'set -e' \
    'CFG=""' \
    'for c in "$HOME/.config/hltm-broker/config.json" /workspace/hltm-broker/config.json; do' \
    '  [ -f "$c" ] && CFG="$c" && break' \
    'done' \
    '[ -n "$CFG" ] || exec codex "$@"' \
    'URL=$(jq -r .url "$CFG")' \
    'KEY=$(jq -r .key "$CFG")' \
    'ACCOUNT="${CX_ACCOUNT:-default}"' \
    'mkdir -p "$HOME/.codex"' \
    'curl -fsS -H "x-broker-key: $KEY" "$URL/getToken?provider=codex&format=authjson&account=$ACCOUNT" -o "$HOME/.codex/auth.json"' \
    'exec codex "$@"' \
    > /usr/local/bin/cx && chmod +x /usr/local/bin/cx

# Non-root user
ARG USER_UID=501
RUN if getent passwd ${USER_UID} >/dev/null; then \
      existing=$(getent passwd ${USER_UID} | cut -d: -f1); \
      usermod -l medulla "$existing"; \
      usermod -d /home/medulla -m medulla || true; \
    else \
      useradd -m -u ${USER_UID} -s /bin/bash medulla; \
    fi \
    && echo "medulla ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/medulla
USER medulla

# agy (antigravity CLI)
RUN curl -fsSL https://antigravity.google/cli/install.sh | bash

# medulla
RUN pipx install git+https://github.com/skopanev/medulla.git
ENV PATH="/home/medulla/.local/bin:$PATH"

ENV MEDULLA_DOCKER=1
ENV GIT_CONFIG_COUNT=2
ENV GIT_CONFIG_KEY_0=safe.directory
ENV GIT_CONFIG_VALUE_0=/workspace
ENV GIT_CONFIG_KEY_1=safe.directory
ENV GIT_CONFIG_VALUE_1=*

WORKDIR /workspace
# init-docker.sh is mounted from the medulla package to /mnt/init-docker.sh at runtime
ENTRYPOINT ["/mnt/init-docker.sh"]
